{
  "name": "amazon-seller-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "amazon-seller-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/httpServer.ts",
    "build": "tsup src/index.ts src/httpServer.ts --format esm --clean",
    "start:http": "node dist/httpServer.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1069.0",
    "@aws-sdk/client-kms": "^3.1069.0",
    "@aws-sdk/client-sqs": "^3.1069.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
